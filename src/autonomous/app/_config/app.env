########################################
#            PYTHON OPTIONS            #
########################################
# Keeps Python from generating .pyc files in the container
PYTHONDONTWRITEBYTECODE=1
# Turns off buffering for easier container logging
PYTHONUNBUFFERED=1

########################################
#            APP OPTIONS            #
########################################
APP_NAME="app"

#######################################
#             DEV OPTIONS             #
#     !!!remove in production!!!      #
#######################################
DEBUG=True

########################################
#            SERVER OPTIONS            #
########################################
PORT=5000
API_PORT=5001
HOST=0.0.0.0