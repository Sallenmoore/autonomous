import torch
from torch import autocast
from diffusers import StableDiffusionPipeline 

class Monster(Model):
    resource = ["monsters"]
    attributes = {
            'name' : str,  
            'size' : str,  
            'type' : str,
            'armor_class' : str,  
            'armor_desc' : str, 
            'hit_points' : str,  
            'hit_dice' : str,  
            'challenge_rating' : str,  
            'img_main': str,
    }

    def img(self):
        modelid = "CompVis/stable-diffusion-v1-4"
        device = "cuda"
        
        pipe = StableDiffusionPipeline.from_pretrained(modelid, revision="fp16", torch_dtype=torch.float16, use_auth_token="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")
        pipe = pipe.to(device)
        
        prompt = f"Portrait of Dungeons and Dragons Character {self.name}"
        with autocast(device):
                image = pipe(prompt.get(), guidance_scale=8.5).images[0]
                image.save(f"/static/images/{self.name}.png")  