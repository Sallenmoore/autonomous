#######################################
#             DEV OPTIONS             #
#     !!!remove in production!!!      #
#######################################
FLASK_ENV=development
FLASK_DEBUG=True
DEBUG=True
ENV=development
TESTING=True

#######################################
#            FLASK OPTIONS            #
#######################################
FLASK_SECRET_KEY="Natasha"


########################################
#            SERVER OPTIONS            #
########################################
PORT=5000
API_PORT=5001
HOST='0.0.0.0'

########################################
#            PYTHON OPTIONS            #
########################################
# Keeps Python from generating .pyc files in the container
PYTHONDONTWRITEBYTECODE=1
# Turns off buffering for easier container logging
PYTHONUNBUFFERED=1

